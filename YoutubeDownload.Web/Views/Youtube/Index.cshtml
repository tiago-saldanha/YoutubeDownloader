@model YoutubePageViewModel

<div class="container mt-5">

    <!-- Header -->
    <div class="text-center mb-4">
        <h1 class="fw-bold">YouTube Downloader</h1>
        <p class="text-muted">Download video and audio streams in your preferred format</p>
    </div>

    <!-- Search form -->
    <div class="card shadow-sm p-4 mb-5">
        <form method="post" asp-action="Index" id="youtube-form">
            <div class="input-group input-group-lg">
                <input type="text"
                       name="url"
                       class="form-control"
                       placeholder="Paste YouTube URL here..."
                       required />

                <button class="btn btn-primary px-4" type="submit">
                    🔍 Search
                </button>

                <a asp-action="Index"
                   asp-controller="Youtube"
                   class="btn btn-outline-secondary px-4">
                    ♻ Reset
                </a>
            </div>
        </form>
    </div>

    <!-- Search Spinner -->
    <div id="loadingSearch" class="text-center mt-3" style="display:none;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p>Searching streams...</p>
    </div>

    <!-- Messages -->
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p><em>@Model.Message</em></p>
    }

    @if (TempData["Alert.Message"] != null)
    {
        <div class="alert alert-@TempData["Alert.Type"] alert-dismissible fade show">
            @TempData["Alert.Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Available streams -->
    @if (Model.Streams.Any())
    {
        <div class="card shadow-sm p-4 mb-5" id="streamsCard">

            <h3 class="mb-4">🎬 Video Download</h3>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Format</th>
                            <th>Video Codec</th>
                            <th>Resolution</th>
                            <th>Size</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stream in Model.Streams.Where(s => !s.IsAudioOnly))
                        {
                            <tr>
                                <td><span class="badge bg-dark">@stream.ContainerName</span></td>
                                <td>
                                    @if (stream.VideoCodec.StartsWith("vp"))
                                    {
                                        <span class="badge bg-primary">
                                            <i class="bi bi-camera-video-fill"></i> @stream.VideoCodec
                                        </span>
                                    }
                                    else if (stream.VideoCodec.StartsWith("avc"))
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-film"></i> @stream.VideoCodec
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark">
                                            <i class="bi bi-music-note"></i> @stream.VideoCodec
                                        </span>
                                    }
                                </td>
                                <td>@stream.Resolution</td>
                                <td>@stream.DisplaySize</td>
                                <td class="text-end">
                                    <form asp-action="Download" method="post" class="d-inline download-form">
                                        <input type="hidden" asp-for="@stream.VideoId" name="VideoId" />
                                        <input type="hidden" asp-for="@stream.Title" name="Title" />
                                        <input type="hidden" asp-for="@stream.ContainerName" name="ContainerName" />
                                        <input type="hidden" asp-for="@stream.VideoCodec" name="VideoCodec" />
                                        <input type="hidden" asp-for="@stream.Resolution" name="Resolution" />
                                        <input type="hidden" asp-for="@stream.Size" name="Size" />
                                        <input type="hidden" asp-for="@stream.IsAudioOnly" name="IsAudioOnly" />
                                        <input type="hidden" asp-for="@stream.AudioCodec" name="AudioCodec" />

                                        <button class="btn btn-outline-warning btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                                style="width: 40px; height: 40px;"
                                                title="Download">
                                            <i class="bi bi-cloud-arrow-down"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <hr class="my-4" />

            <h3 class="mb-4">🎵 Audio Download</h3>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Format</th>
                            <th>Audio Codec</th>
                            <th>Size</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stream in Model.Streams.Where(s => s.IsAudioOnly))
                        {
                            <tr>
                                <td><span class="badge bg-dark">@stream.ContainerName</span></td>
                                <td>
                                    @if (stream.AudioCodec.Contains("mp4a"))
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-music-note-beamed"></i> @stream.AudioCodec
                                        </span>
                                    }
                                    else if (stream.AudioCodec.Contains("opus"))
                                    {
                                        <span class="badge bg-info text-dark">
                                            <i class="bi bi-music-note"></i> @stream.AudioCodec
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@stream.AudioCodec</span>
                                    }
                                </td>
                                <td>@stream.DisplaySize</td>
                                <td class="text-end">
                                    <form asp-action="Download" method="post" class="d-inline download-form">
                                        <input type="hidden" asp-for="@stream.VideoId" name="VideoId" />
                                        <input type="hidden" asp-for="@stream.Title" name="Title" />
                                        <input type="hidden" asp-for="@stream.ContainerName" name="ContainerName" />
                                        <input type="hidden" asp-for="@stream.VideoCodec" name="VideoCodec" />
                                        <input type="hidden" asp-for="@stream.Resolution" name="Resolution" />
                                        <input type="hidden" asp-for="@stream.Size" name="Size" />
                                        <input type="hidden" asp-for="@stream.IsAudioOnly" name="IsAudioOnly" />
                                        <input type="hidden" asp-for="@stream.AudioCodec" name="AudioCodec" />

                                        <button class="btn btn-outline-warning btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                                style="width: 40px; height: 40px;"
                                                title="Download">
                                            <i class="bi bi-cloud-arrow-down"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    }

</div>

<!-- Global Overlay -->
<div id="overlay" style="
    display:none;
    position:fixed;
    top:0; left:0;
    width:100%; height:100%;
    background: rgba(0,0,0,0.4);
    z-index:9999;
    text-align:center;
    padding-top:20%;
    color:white;
">
    <div class="spinner-border text-light" role="status"></div>
    <p>Processing download...</p>
</div>