@if (!string.IsNullOrWhiteSpace(ThumbnailUrl))
{
    <MudCard Class="@_class">

        <MudCardMedia Image="@ThumbnailUrl" Height="468" />

        <MudCardContent>

            <MudText Typo="Typo.subtitle1" Class="mt-1">
                @Title
            </MudText>

        </MudCardContent>

    </MudCard>
}

@code {
    [Parameter] public string ThumbnailUrl { get; set; } = string.Empty;

    [Parameter] public bool HasResults { get; set; }

    [Parameter] public string Title { get; set; } = string.Empty;

    private string _class => HasResults ? "mt-4 thumbnail-card thumb-visible" : "mt-4 thumbnail-card thumb-hidden";
}
