@page "/"

@inject IYoutubeAppService YoutubeAppService
@inject NavigationManager Navigation
@inject IDeviceService DeviceService
@implements IDisposable

@using YoutubeDownloader.Domain.Commands
@using YoutubeDownloader.SharedUI.Components.Shared
@using YoutubeDownloader.SharedUI.Interfaces
@using YoutubeDownloader.SharedUI.Models
@using YoutubeDownloader.SharedUI.Components.Pages.Streams

<PageTitle>Youtube Downloader</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">

    <div class="search-container @(_hasSearched ? "search-top" : "search-center")">
        <MudStack AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.subtitle1">
                Download video and audio streams in your preferred format
            </MudText>
        </MudStack>

        <MudCard Elevation="3" Class="pa-4">

            <Search 
                @bind-Url="@ViewModel.Url" 
                IsDownloading="@_isDownloading" 
                OnSearch="Search" />

            <Thumbnail 
                ThumbnailUrl="@ViewModel.ThumbnailUrl" 
                HasResults="@ViewModel.HasResults" 
                Title="@ViewModel.Title" />

            <LoadingProgressLinear 
                IsSearching="@_isSearching" 
                StatusMessage="@_statusMessage" 
                DownloadPercent="@_downloadPercent" />

            <MudCard Class="@_thumbnailClass">

                <YoutubeVideoStreams streams="@ViewModel.VideoStreams"
                                     DownloadingStreamId="@_downloadingStreamId"
                                     DownloadPercent="@_downloadPercent"
                                     IsDownloading="@_isDownloading"
                                     OnClickCallback="DownloadAsync"
                                     OnCancel="CancelDownload" />

                <YoutubeAudioStreams streams="@ViewModel.AudioStreams"
                                     DownloadingStreamId="@_downloadingStreamId"
                                     DownloadPercent="@_downloadPercent"
                                     IsDownloading="@_isDownloading"
                                     OnClickCallback="DownloadAsync"
                                     OnCancel="CancelDownload" />

            </MudCard>

        </MudCard>
    </div>

</MudContainer>

@code {

    private CancellationTokenSource? _cancelationTokenSource;
    private YoutubePageViewModel ViewModel = new();
    private bool _isSearching;
    private bool _hasSearched = false;
    private int _downloadPercent;
    private string _statusMessage = "";
    private string? _downloadingStreamId;
    private int _lastReportedPercent = -1;
    private bool _isDownloading => !string.IsNullOrEmpty(_downloadingStreamId);
    private string _thumbnailClass => $"mt-4 thumbnail-card {(ViewModel.HasResults ? "thumb-visible" : "thumb-hidden")}";

    private async Task Search()
    {
        _hasSearched = false;
        _isSearching = true;
        _statusMessage = "Searching video...";

        ViewModel.ClearStreams();
        await InvokeAsync(StateHasChanged);
        await ViewModel.SearchAsync(YoutubeAppService);

        _isSearching = false;
        _hasSearched = true;
    }

    private async Task DownloadAsync(StreamViewModel stream)
    {
        _cancelationTokenSource = new CancellationTokenSource();

        _statusMessage = "Starting download...";
        _downloadPercent = 0;
        _downloadingStreamId = stream.Id;

        await InvokeAsync(StateHasChanged);

        try
        {

            var command = new DownloadCommand(
                    stream.VideoId,
                    stream.Title,
                    stream.ContainerName,
                    stream.VideoCodec,
                    stream.Resolution,
                    stream.AudioCodec,
                    stream.IsAudioOnly
                );

            var progress = new Progress<double>(p =>
            {
                var percent = (int)Math.Floor(p * 100);

                if (percent != _lastReportedPercent)
                {
                    _lastReportedPercent = percent;

                    _downloadPercent = percent;
                    _statusMessage = $"Downloading {stream.ContainerName} {percent}%";

                    InvokeAsync(StateHasChanged);
                }
            });

            var download = await YoutubeAppService.DownloadFileAsync(
                command,
                progress,
                _cancelationTokenSource.Token);

            _downloadingStreamId = null;

            if (DeviceService.Desktop)
            {
                _statusMessage = $"Download concluído com sucesso!";
                await DeviceService.OpenFileAsync(download.FilePath);
            }
            else
            {
                Navigation.NavigateTo($"/api/download/{download.Id}", true);
                _statusMessage = "Download pronto! O navegador iniciará a transferência.";
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            _statusMessage = "Download cancelado pelo usuário.";
        }
        catch (Exception ex)
        {
            _statusMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            _downloadingStreamId = null;
            _cancelationTokenSource?.Dispose();
            _cancelationTokenSource = null;

            await InvokeAsync(StateHasChanged);
        }
    }

    private void CancelDownload()
    {
        _cancelationTokenSource?.Cancel();
        _statusMessage = "Cancelando Download...";
    }

    public void Dispose()
    {
        _cancelationTokenSource?.Cancel();
        _cancelationTokenSource?.Dispose();
    }
}
