@page "/youtube"

@inject IYoutubeAppService Service
@inject IFileSaveService FileService
@inject NavigationManager Navigation

@using YoutubeDownloader.Core.Interfaces
@using YoutubeDownloader.Domain.Commands
@using YoutubeDownloader.Maui.Components.Pages.Youtube.Audio
@using YoutubeDownloader.Maui.Components.Pages.Youtube.Video
@using YoutubeDownloader.Maui.Models

<PageTitle>Youtube Download</PageTitle>

<div class="text-center mb-4">
    <h1 class="fw-bold">YouTube Download</h1>
    <p class="text-muted">Download video and audio streams in your preferred format</p>
</div>

<div class="card shadow-sm p-4 mb-5">

    <div class="input-group input-group">
        <input class="form-control" name="url"
        placeholder="Paste YouTube URL here..."
        @bind="ViewModel.Url" />

        <button class="btn btn-primary" @onclick="Search">
            🔍 Search
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(ViewModel.Title))
    {
        <p class="text-muted">Título: @ViewModel.Title</p>
    }

    <YoutubeVideoStreams streams="@ViewModel.VideoStreams" OnClickCallback="(stream) => DownloadAsync(stream)" />
    <YoutubeAudioStreams streams="@ViewModel.AudioStreams" OnClickCallback="(stream) => DownloadAsync(stream)" />
</div>

@code {

    [Parameter]
    public EventCallback<StreamViewModel> OnClickCallback { get; set; }

    private YoutubePageViewModel ViewModel = new();

    private async Task Search()
    {
        await ViewModel.SearchAsync(Service);
    }

    private async Task DownloadAsync(StreamViewModel stream)
    {
        var command = new DownloadCommand(
            stream.VideoId,
            stream.Title,
            stream.ContainerName,
            stream.VideoCodec,
            stream.Resolution,
            stream.AudioCodec,
            stream.IsAudioOnly
        );

        var download = await Service.DownloadFileAsync(command, null, new CancellationToken());

        await FileService.SaveAsync(download.FilePath, download.FileName);
    }
}