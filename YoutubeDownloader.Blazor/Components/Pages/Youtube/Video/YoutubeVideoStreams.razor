@using YoutubeDownloader.Domain.Commands
@using YoutubeDownloader.Blazor.Models

@if (streams.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mt-6 mb-2">
        🎬 Video Download
    </MudText>

    <MudTable Items="streams"
              Hover="true"
              Dense="true"
              Elevation="1">

        <HeaderContent>
            <MudTh>Format</MudTh>
            <MudTh>Video Codec</MudTh>
            <MudTh>Resolution</MudTh>
            <MudTh>Size</MudTh>
            <MudTh Align="Align.Right"></MudTh>
        </HeaderContent>

        <RowTemplate>

            <MudTd>
                <MudChip T="string" Color="Color.Dark"
                         Variant="Variant.Filled"
                         Size="Size.Small">
                    @context.ContainerName
                </MudChip>
            </MudTd>

            <MudTd>
                @GetCodecChip(context.VideoCodec)
            </MudTd>

            <MudTd>
                @context.Resolution
            </MudTd>

            <MudTd>
                @context.DisplaySize
            </MudTd>

            <MudTd Align="Align.Right">

                @if (DownloadingStreamId == context.Id)
                {
                    <MudStack Style="width:150px">

                        <MudProgressLinear Value="@DownloadPercent"
                                           Color="Color.Primary"
                                           Rounded="true" />

                        <MudText Typo="Typo.caption">
                            @DownloadPercent%
                        </MudText>

                    </MudStack>
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.CloudDownload"
                                   Color="Color.Warning"
                                   Variant="Variant.Outlined"
                                   Size="Size.Medium"
                                   OnClick="() => DownloadAsync(context)" />
                }

            </MudTd>

        </RowTemplate>

    </MudTable>
}

@code {

    [Parameter]
    public List<StreamViewModel> streams { get; set; } = [];

    [Parameter]
    public EventCallback<StreamViewModel> OnClickCallback { get; set; }

    [Parameter]
    public string? DownloadingStreamId { get; set; }

    [Parameter]
    public int DownloadPercent { get; set; }

    private async Task DownloadAsync(StreamViewModel stream)
    {
        await OnClickCallback.InvokeAsync(stream);
    }

    private RenderFragment GetCodecChip(string codec) => builder =>
    {
        Color color = Color.Info;
        string icon = Icons.Material.Filled.VideoFile;

        if (codec.StartsWith("vp"))
        {
            color = Color.Primary;
            icon = Icons.Material.Filled.Videocam;
        }
        else if (codec.StartsWith("avc"))
        {
            color = Color.Success;
            icon = Icons.Material.Filled.Movie;
        }

        builder.OpenComponent<MudChip<string>>(0);
        builder.AddAttribute(1, "Color", color);
        builder.AddAttribute(2, "StartIcon", icon);
        builder.AddAttribute(3, "Size", Size.Small);
        builder.AddAttribute(4, "ChildContent", (RenderFragment)((b) =>
        {
            b.AddContent(5, codec);
        }));
        builder.CloseComponent();
    };

}