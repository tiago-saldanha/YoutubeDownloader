@page "/youtube"
@rendermode InteractiveServer

@inject IYoutubeAppService Service
@inject DownloadApiClient DownloadClient
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@using YoutubeDownloader.Domain.Commands
@using YoutubeDownloader.Blazor.Components.Pages.Youtube.Audio
@using YoutubeDownloader.Blazor.Components.Pages.Youtube.Video
@using YoutubeDownloader.Blazor.Models

<PageTitle>Youtube Download</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">

    <MudStack AlignItems="AlignItems.Center" Class="mt-6">
        <MudText Typo="Typo.h5" GutterBottom="true">
            YouTube Downloader
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
            Download video and audio streams in your preferred format
        </MudText>
    </MudStack>

    <MudCard Elevation="3" Class="pa-4 mb-6">

        <MudStack Row="true" Spacing="2">

            <MudTextField T="string"
                          Placeholder="Paste YouTube URL here..."
                          @bind-Value="ViewModel.Url"
                          FullWidth="true" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="Search"
                       StartIcon="@Icons.Material.Filled.Search">

                Search

            </MudButton>

        </MudStack>

        @if (!string.IsNullOrWhiteSpace(ViewModel.Title))
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mt-3">
                Title: @ViewModel.Title
            </MudText>
        }

        <YoutubeVideoStreams streams="@ViewModel.VideoStreams"
                             OnClickCallback="(stream) => DownloadAsync(stream)" />

        <YoutubeAudioStreams streams="@ViewModel.AudioStreams"
                             OnClickCallback="(stream) => DownloadAsync(stream)" />

    </MudCard>

</MudContainer>

@code {

    [Parameter]
    public EventCallback<StreamViewModel> OnClickCallback { get; set; }

    public string Message { get; set; } = "";

    public bool IsLoading { get; set; }

    private int _lastReportedPercent = -1;

    private YoutubePageViewModel ViewModel = new();

    private async Task Search()
    {
        ViewModel.ClearStreams();
        await JSRuntime.InvokeVoidAsync("showLoading", "Searching...");
        await ViewModel.SearchAsync(Service);
        await JSRuntime.InvokeVoidAsync("hideLoading");
    }

    private async Task DownloadAsync(StreamViewModel stream)
    {
        await JSRuntime.InvokeVoidAsync("showLoading", "Downloading...");

        var command = new DownloadCommand(
            stream.VideoId,
            stream.Title,
            stream.ContainerName,
            stream.VideoCodec,
            stream.Resolution,
            stream.AudioCodec,
            stream.IsAudioOnly
        );

        var progress = new Progress<double>(async p =>
        {
            var percent = (int)Math.Floor(p * 100);

            if (percent % 1 == 0 && percent != _lastReportedPercent)
            {
                _lastReportedPercent = percent;

                await JSRuntime.InvokeVoidAsync(
                    "showLoading",
                    $"Downloading {percent.ToString("F2")}%");
            }
        });

        var download = await Service.DownloadFileAsync(command, progress, new CancellationToken());

        await JSRuntime.InvokeVoidAsync("hideLoading");

        Navigation.NavigateTo($"/api/download/{download.Id}", true);

    }
}