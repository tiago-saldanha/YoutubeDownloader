@inherits LayoutComponentBase

<MudLayout>

    <MudAppBar Elevation="0" Dense="true" Class="px-6">

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">

            <MudIcon Icon="@Icons.Material.Filled.SmartDisplay"
                     Color="Color.Primary" />

            <MudText Typo="Typo.h6">
                Youtube Downloader
            </MudText>

        </MudStack>

        <MudSpacer />

        <MudStack Row="true" Spacing="2">

            <MudButton Variant="Variant.Text"
                       Color="Color.Inherit"
                       Href="https://github.com/tiago-saldanha/YoutubeDownloader"
                       Target="_blank">

                <MudIcon Icon="fa-brands fa-github" Class="mr-2" />

                Github

            </MudButton>

        </MudStack>

    </MudAppBar>

    <MudMainContent>

        <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
            @Body
        </MudContainer>

    </MudMainContent>

</MudLayout>

@code {

    [CascadingParameter] private bool _isDarkMode { get; set; }

    void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }

}